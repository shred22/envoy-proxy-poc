# ── Certificates (generated by gen-certs.sh, never commit private keys) ──────
certs/

# ── OpenShift generated Secret manifest (contains base64-encoded keys) ────────
openshift/tls-secret.yaml

# ── Spring Boot build output ──────────────────────────────────────────────────
spring-boot-app/target/

# ── Maven wrapper cache ───────────────────────────────────────────────────────
spring-boot-app/.mvn/
spring-boot-app/mvnw
spring-boot-app/mvnw.cmd

# ── Go build output ───────────────────────────────────────────────────────────
mocks/grpc-echo/proto/
mocks/grpc-echo/grpc-echo

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
*.env
.env.local

.claude/**
